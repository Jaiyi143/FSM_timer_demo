//top level design seq 0110 with 7-segment display
module top_seq_0110 (out, hex, clk_led, clk_in, rst_n, in);

// ports
input 		 in;
input 		 rst_n;
input 		 clk_in;
output 		 clk_led;
output 		 out;
output [0:6] hex;

// nets
wire clk_w;
wire [2:0] state_w;

// clock divider instance
clk_div #(.PERIOD_OUT(3)) clk_div_ins(
    .clk_in(clk_in),
    .clk_out(clk_w),
    .clk_led(clk_led)
);

// seq instance
seq_0110 seq0110(
    .out(out),
    .state(state_w),
    .in(in),
    .clk(clk_w),
    .rst_n(rst_n)
);

// 7-segment instance
bcd_7seg seg7(
    .hex(hex),
    .bcd(state_w)
);

endmodule